# Server
PORT=5000
NODE_ENV=development

# MongoDB (use MongoDB Atlas connection string for production)
MONGODB_URI=mongodb://localhost:27017/fleetflow-ai

# JWT
JWT_SECRET=supersecretkey
JWT_EXPIRE=7d

# Gemini API (get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=AIzaSyA_jxgXXPhQTwXckfiiBWbXO8zLeagjfrM

# CORS (comma-separated). Include every browser origin that calls the API (local + Vercel preview/production).
# Example: http://localhost:3000,https://fleetflow.vercel.app,https://fleetflow-git-main-you.vercel.app
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Public web app URL (invite links use the first entry). In production set to your Vercel URL, e.g. https://fleetflow.vercel.app
FRONTEND_URL=http://localhost:3000
